            <section ID="LINK_09a7f82e-96d2-4850-8974-260a8b12e54f">
               <id root="d8d93832-21a1-413d-8b34-da0a5da60eba"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>CAUTION</title>
               <text>
                  <paragraph>Federal law restricts this drug to use by or on the order of a licensed veterinarian.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20241114"/>
            </section>
