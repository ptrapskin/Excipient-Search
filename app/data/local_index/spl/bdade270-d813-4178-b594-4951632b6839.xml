                     <item>store at room temperature</item>
                     <item>dosage cup provided</item>
                     <item>
                        <content styleCode="bold">do not use if printed bottle wrap is missing or broken</content>
                     </item>
                     <item>see bottom panel for lot number and expiration date</item>
                  </list>
               </text>
               <effectiveTime value="20181109"/>
            </section>
