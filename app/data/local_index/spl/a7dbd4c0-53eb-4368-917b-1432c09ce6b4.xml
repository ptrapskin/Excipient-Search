               <text>
                  <paragraph>
                     <content styleCode="bold">﻿Inactive ingredients: </content>﻿artificial and natural cherry flavor, citric acid, FD&amp;C Red #40, methylparaben, polyethylene glycol, propylene glycol, propylparaben, purified water, sodium citrate, sucralose

 </paragraph>
               </text>
               <effectiveTime value="20220710"/>
            </section>
