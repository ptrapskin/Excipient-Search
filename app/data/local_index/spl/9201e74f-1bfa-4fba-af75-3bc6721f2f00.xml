            <section>
               <id root="836dd2da-efd2-4729-8f17-6d0fd4ef2332"/>
               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title>Drug Facts</title>
               <text>
                  <paragraph>Active Ingredient: Acetaminophen 80 mg (in each 0.8 mL) <br/>
                  </paragraph>
               </text>
               <effectiveTime value="20101222"/>
            </section>
