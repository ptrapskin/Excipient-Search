               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title>
                  <content styleCode="bold">Active ingredient (in each 5 mL-teaspoonful)</content>
               </title>
               <text>
                  <paragraph>Acetaminophen 160mg</paragraph>
               </text>
               <effectiveTime value="20260118"/>
            </section>
