               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>
                  <content styleCode="bold italics">Other information</content>
               </title>
               <text>
                  <paragraph>store between 20-25ºC (68-77ºF)</paragraph>
               </text>
               <effectiveTime value="20101008"/>
