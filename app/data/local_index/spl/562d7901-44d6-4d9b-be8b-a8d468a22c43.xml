               <text>
                  <paragraph>
                     <content styleCode="bold">Active ingredient</content>(in each 5mL)                                            
 
  <content styleCode="bold">Purpose</content>
                     <br/>  Acetaminophen 160 mg ………………………….........Pain reliever/fever reducer

 </paragraph>
               </text>
